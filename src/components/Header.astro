---
import LanguagePicker from './LanguagePicker.astro';
import Navigation from './Navigation.astro';
---

<header class="w-full bg-background border-b border-secondary/20">
    <div class="max-w-7xl mx-auto px-4 md:px-8 h-16 flex items-center justify-between">
        <a href="/" class="text-2xl font-bold text-primary tracking-tighter">
            INSTITUT OF VIDA SALVAJE
        </a>
    
        <div class="flex items-center gap-4">
            <LanguagePicker />
        </div>
    </div>

    <div class="hidden md:block border-t border-secondary/10">
        <div class="max-w-7xl mx-auto px-8">
            <Navigation />
        </div>
    </div>
</header>