---
import LanguagePicker from './LanguagePicker.astro';
import Navigation from './Navigation.astro';
import { cn } from '../utils/cn';

interface Props {
    class?: string;
}

const { class: className } = Astro.props;
---

<header class={cn("w-full bg-background/95 backdrop-blur-md sticky top-0 z-40 border-b border-secondary/20", className)}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="text-2xl font-bold text-primary tracking-tighter flex items-center gap-2">
            <span>INSTITUT OF VIDA SALVAJE</span>
        </a>
    
        <div class="flex items-center gap-4">
            <LanguagePicker />
      
            <button class="md:hidden p-2 text-foreground" aria-label="Buka Menu">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
            </button>
        </div>
    </div>

    <div class="hidden md:block border-t border-secondary/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <Navigation />
        </div>
    </div>
</header>