---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { languages } from '../i18n/ui';
import { cn } from '../utils/cn';

interface Props {
    class?: string;
}

const { class: className } = Astro.props;

const currentPath = Astro.url.pathname.replace(/^\/(en|zh|de|ja|ko)\//, '/');
---

<div class={cn("flex items-center gap-3", className)}>
    {Object.entries(languages).map(([langCode, langName]) => (
        <a 
        href={getRelativeLocaleUrl(langCode, currentPath)}
        class="text-sm font-medium text-foreground/80 hover:text-primary transition-colors uppercase tracking-wider"
        title={langName}
        aria-label={`Ganti bahasa ke ${langName}`}
        >
            {langCode}
        </a>
    ))}
</div>